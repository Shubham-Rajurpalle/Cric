<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#0022AA" android:endColor="#0077CC" android:angle="135"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#0033CC" android:endColor="#0099FF" android:angle="135"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</selector>