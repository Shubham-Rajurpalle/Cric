<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_update_dialog"
    android:padding="0dp">

    <!-- Top gradient banner -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_update_banner">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:src="@mipmap/ic_launcher_round"
            android:elevation="4dp"/>

        <!-- Version badge -->
        <TextView
            android:id="@+id/tvVersionBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="12dp"
            android:background="@drawable/bg_version_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="NEW VERSION"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"/>
    </FrameLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Update Available"
            android:textColor="#1A1A2E"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="A new version of Cricket App is ready. Update now for the latest features and improvements."
            android:textColor="#666680"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.4"/>

        <!-- Progress section (hidden initially) -->
        <LinearLayout
            android:id="@+id/layoutProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvDownloadStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Downloading..."
                    android:textColor="#1A1A2E"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvProgressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#0066FF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Custom progress bar -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@drawable/bg_progress_track">

                <View
                    android:id="@+id/progressFill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_progress_fill"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvDownloadSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textColor="#999999"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Download button (shown initially) -->
        <TextView
            android:id="@+id/btnDownload"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_download_button"
            android:gravity="center"
            android:text="⬇  Download Update"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"/>

    </LinearLayout>
</LinearLayout>